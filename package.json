{
  "name": "tsundoku",
  "version": "0.1.0-a",
  "description": "Personal manga library manager",
  "license": "AGPL-3.0-or-later",
  "author": "Sergio Fernández Celorio <scelorio1990@gmail.com>",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"dotenv -e .env -- npm run server\" \"dotenv -e .env -- npm run client\"",
    "client": "vite --host",
    "server": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "pinia": "^2.2.2",
    "vue": "^3.5.38",
    "vue-i18n": "^10.0.8",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.3",
    "@vue/test-utils": "^2.4.11",
    "concurrently": "^9.0.1",
    "dotenv-cli": "^7.4.2",
    "happy-dom": "^20.10.4",
    "supertest": "^7.2.2",
    "vite": "^5.4.5",
    "vitest": "^4.1.9"
  }
}
